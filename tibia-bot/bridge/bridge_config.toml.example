# bridge_config.toml — Copiar a bridge_config.toml y editar para tu hardware.
# Colocar en el mismo directorio que NewEra-bridge.exe antes de ejecutarlo.

# ── Modo de input ──────────────────────────────────────────────────────────
# El bridge soporta 2 backends de actuación HID:
#
#   "serial":    (DEFAULT + RECOMENDADO PARA LIVE) forwardea comandos via
#                puerto serial COM a un microcontrolador con USB HID nativo
#                (Pico 2, Arduino Leonardo, Pro Micro). Los eventos llegan
#                al SO como hardware real — indistinguibles de mouse/teclado
#                físico. **Inmune a BattleEye y anti-cheats que monitorean
#                Windows SendInput / SetWindowsHookEx**. Requiere device
#                conectado.
#
#   "sendinput": usa la Windows API SendInput para inyectar mouse/keyboard.
#                NO requiere hardware. **DETECTABLE por BattleEye** —
#                cualquier anti-cheat moderno flaguea procesos llamando
#                SendInput/PostMessage sobre una ventana de juego. Usar
#                SOLO para dev/testing sin cuenta real en riesgo.
[input]
mode = "serial"   # default anti-detection. Cambiar a "sendinput" solo si no tenés Arduino.

# ── Configuración serial (solo si mode = "serial") ─────────────────────────
# Soporta tanto Raspberry Pi Pico 2 como Arduino Leonardo / Pro Micro.
# Ambos hablan el mismo protocolo line-based ASCII a 115200 baud.
#
# Para Arduino Leonardo: ver arduino/README.md para flash del sketch.
[serial]
# Puerto COM asignado al device por Windows.
# Verificar en Administrador de dispositivos > Puertos (COM y LPT).
# Pico 2:   aparece como "USB Serial Device (COMx)"
# Leonardo: aparece como "Arduino Leonardo (COMx)"
port = "COM5"
baud = 115200

[tcp]
# El bridge escucha aquí. El bot del PC procesador se conecta a esta IP:puerto.
listen_addr = "0.0.0.0:9000"

[watchdog]
# Watchdog de inactividad del bot. Si no llega ningún comando del bot durante
# N segundos, el bridge cierra la conexión TCP. Esto previene "clicks fantasma"
# si el bot crashea o se cuelga: al perder la conexión, no quedan comandos
# huérfanos ejecutándose.
#
# El bot real envía PING ~cada tick (33ms a 30 Hz) cuando está vivo, así que
# valores entre 5s y 30s son seguros. 0 desactiva el watchdog.
idle_timeout_secs = 10

[focus]
# Detección de foco: si Tibia no es la ventana activa, el bridge bloquea
# comandos HID (MOUSE_MOVE, MOUSE_CLICK, KEY_TAP) para evitar que keystrokes
# y clicks vayan a la ventana equivocada.
#
# **Anti-detection 2026-04-17**: focus detection usa GetForegroundWindow +
# GetWindowTextW cada N ms para leer el título de la ventana activa.
# BattleEye (y anti-cheats similares) flagean procesos que polan estas APIs
# a alta frecuencia (<500ms). Default subido a 2000ms + debounce reducido
# a 2 → 4s de tolerancia. Para mayor sigilo, setear enabled=false (el bot
# pierde el safety contra alt-tab pero evita todo el API polling).
#
# Trade-off de enabled=true @ 2000ms: si alt-tab accidentalmente por <2s, el
# bot puede ejecutar 1-2 acciones con foco perdido antes de pausar. Es
# manejable; el bot recupera solo al volver el foco.
enabled = true
# Substring a buscar en el título de la ventana activa.
# Tibia usa "Tibia - NombrePersonaje" como título.
window_title_contains = "Tibia"
# Intervalo de polling en ms. Default 2000ms (anti-detection). Valores
# más bajos (<500ms) son fingerprintables como software de automation.
poll_interval_ms = 2000
# Polls consecutivos "sin foco" antes de declarar pérdida real.
# 2 × 2000ms = 4s debounce — absorbe popups cortos y latency de
# window-switching sin bloquear comandos.
debounce_count = 2
